{
    "name": "veterinaria/hexagonal",
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Test\\": "tests/"
        }
    },
    "require": {
        "vlucas/phpdotenv": "^5.6",
        "ext-pdo": "*",
        "ext-pdo_mysql": "*"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5.63",
        "behat/behat": "^3.31",
        "infection/infection": "^0.32.6"
    },
    "config": {
        "allow-plugins": {
            "infection/extension-installer": true
        }
    }
}