{
    "name": "veterinaria/hexagonal",
    "autoload": {
        "psr-4": {
            "Domain\\": "Domain/",
            "Application\\": "Application/",
            "Infrastructure\\": "Infrastructure/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5.63",
        "behat/behat": "^3.31",
        "infection/infection": "^0.32.6"
    },
    "config": {
        "allow-plugins": {
            "infection/extension-installer": true
        }
    }
}
